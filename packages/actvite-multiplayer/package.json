{
    "name": "actvite-multiplayer",
    "version": "0.1.0",
    "description": "Multiplayer shared state layer for Act-Vite Discord Activities.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        },
        "./server": {
            "import": "./dist/server.js",
            "require": "./dist/server.cjs",
            "types": "./dist/server.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run --passWithNoTests",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "ws": ">=8.0.0"
    },
    "peerDependenciesMeta": {
        "ws": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/ws": "^8.5.10",
        "tsup": "^8.0.0",
        "typescript": "^5.4.0"
    },
    "keywords": [
        "discord",
        "activity",
        "multiplayer",
        "shared-state",
        "websocket",
        "actvite"
    ],
    "license": "MIT"
}